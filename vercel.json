{
  "version": 2,
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "framework": "vite",

  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node@latest"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/public/index.html"
    }
  ]
}
